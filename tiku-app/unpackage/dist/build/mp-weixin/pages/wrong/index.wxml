<view class="container data-v-63e251b2"><view class="header data-v-63e251b2"><view class="header-title data-v-63e251b2">错题本</view><view class="header-sub data-v-63e251b2">{{$root.g0+" 道错题"}}</view></view><block wx:if="{{$root.g1>0}}"><view class="action-bar data-v-63e251b2"><view data-event-opts="{{[['tap',[['practiceWrong',['$event']]]]]}}" class="action-btn data-v-63e251b2" bindtap="__e">🎯 错题重做</view><view data-event-opts="{{[['tap',[['clearAll',['$event']]]]]}}" class="action-btn danger data-v-63e251b2" bindtap="__e">🗑 清空</view></view></block><block wx:if="{{$root.g2>0}}"><view class="list data-v-63e251b2"><block wx:for="{{wrongList}}" wx:for-item="item" wx:for-index="idx" wx:key="idx"><view data-event-opts="{{[['tap',[['goPractice',[idx]]]]]}}" class="item data-v-63e251b2" bindtap="__e"><view class="item-idx data-v-63e251b2">{{idx+1}}</view><view class="item-content data-v-63e251b2"><view class="item-type data-v-63e251b2">{{"【"+(item.question.type||'选择题')+"】"}}</view><view class="item-stem data-v-63e251b2">{{item.question.stem}}</view><view class="item-meta data-v-63e251b2"><text class="meta-wrong data-v-63e251b2">{{"错"+item.wrongData.times+"次"}}</text><text class="meta-answer data-v-63e251b2">{{"我的答案："+item.wrongData.lastAnswer}}</text><text class="meta-correct data-v-63e251b2">{{"正确："+item.question.answer}}</text></view></view><view data-event-opts="{{[['tap',[['removeItem',[idx]]]]]}}" class="item-del data-v-63e251b2" catchtap="__e">✖</view></view></block></view></block><block wx:else><view class="empty data-v-63e251b2"><view class="empty-icon data-v-63e251b2">🎉</view><view class="empty-text data-v-63e251b2">暂无错题，继续保持！</view></view></block></view>