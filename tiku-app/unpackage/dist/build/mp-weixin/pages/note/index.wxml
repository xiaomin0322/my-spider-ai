<view class="container data-v-b8fcacc2"><view class="header data-v-b8fcacc2"><view class="header-title data-v-b8fcacc2">我的笔记</view><view class="header-sub data-v-b8fcacc2">{{$root.g0+" 条笔记"}}</view></view><block wx:if="{{$root.g1>0}}"><view class="list data-v-b8fcacc2"><block wx:for="{{noteList}}" wx:for-item="item" wx:for-index="idx" wx:key="idx"><view data-event-opts="{{[['tap',[['goQuestion',[idx]]]]]}}" class="item data-v-b8fcacc2" bindtap="__e"><view class="item-icon data-v-b8fcacc2">📝</view><view class="item-content data-v-b8fcacc2"><view class="item-stem data-v-b8fcacc2">{{item.question.stem}}</view><view class="item-note data-v-b8fcacc2">{{item.noteData.content}}</view><view class="item-meta data-v-b8fcacc2"><text class="data-v-b8fcacc2">{{item.question.subject+" · "+item.question.chapter}}</text><text class="meta-time data-v-b8fcacc2">{{item.noteData.time}}</text></view></view><view data-event-opts="{{[['tap',[['removeItem',[idx]]]]]}}" class="item-del data-v-b8fcacc2" catchtap="__e">✖</view></view></block></view></block><block wx:else><view class="empty data-v-b8fcacc2"><view class="empty-icon data-v-b8fcacc2">📝</view><view class="empty-text data-v-b8fcacc2">暂无笔记</view><view class="empty-hint data-v-b8fcacc2">答题时可添加笔记记录学习心得</view></view></block></view>