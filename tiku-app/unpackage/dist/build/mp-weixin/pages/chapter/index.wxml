<view class="container data-v-824960cc"><view class="header data-v-824960cc"><view class="header-title data-v-824960cc">{{subject}}</view><view class="header-sub data-v-824960cc">{{"共 "+totalQuestions+" 题"}}</view></view><view class="chapter-list data-v-824960cc"><block wx:for="{{chapters}}" wx:for-item="chap" wx:for-index="idx" wx:key="idx"><view data-event-opts="{{[['tap',[['goPractice',['$0',idx],[[['chapters','',idx]]]]]]]}}" class="chapter-item data-v-824960cc" bindtap="__e"><view class="chap-idx data-v-824960cc">{{idx+1}}</view><view class="chap-info data-v-824960cc"><view class="chap-name data-v-824960cc">{{chap.name}}</view><view class="chap-meta data-v-824960cc"><text class="data-v-824960cc">{{chap.count+"题"}}</text><block wx:if="{{chapStats[chap.name]}}"><text class="chap-progress data-v-824960cc">{{'· 已答'+chapStats[chap.name].answered+"题\n            · 正确率"+chapStats[chap.name].rate+'%'}}</text></block></view></view><view class="chap-arrow data-v-824960cc">›</view></view></block></view></view>