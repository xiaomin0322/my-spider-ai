<view class="container data-v-611e11c9"><block wx:if="{{!started}}"><view class="start-screen data-v-611e11c9"><view class="start-icon data-v-611e11c9">🎯</view><view class="start-title data-v-611e11c9">模拟考试</view><view class="start-info data-v-611e11c9"><view class="info-row data-v-611e11c9"><text class="info-label data-v-611e11c9">考试类型</text><text class="info-value data-v-611e11c9">{{typeName}}</text></view><view class="info-row data-v-611e11c9"><text class="info-label data-v-611e11c9">题目数量</text><text class="info-value data-v-611e11c9">{{$root.g0+" 题"}}</text></view><view class="info-row data-v-611e11c9"><text class="info-label data-v-611e11c9">考试时间</text><text class="info-value data-v-611e11c9">{{totalMinutes+" 分钟"}}</text></view></view><view data-event-opts="{{[['tap',[['startExam',['$event']]]]]}}" class="start-btn data-v-611e11c9" bindtap="__e">开始考试</view><view class="start-tip data-v-611e11c9">考试期间不可查看答案，交卷后显示成绩</view></view></block><block wx:if="{{started&&!finished}}"><view class="top-bar data-v-611e11c9"><view class="timer data-v-611e11c9"><text class="timer-icon data-v-611e11c9">⏱</text><text class="{{['timer-text','data-v-611e11c9',(remainSeconds<300)?'urgent':'']}}">{{$root.m0}}</text></view><view class="progress-text data-v-611e11c9">{{currentIdx+1+"/"+$root.g1}}</view><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="top-action data-v-611e11c9" bindtap="__e">☰</view></view><view class="progress-bar data-v-611e11c9"><view class="progress-fill data-v-611e11c9" style="{{'width:'+(progressPercent+'%')+';'}}"></view></view><block wx:if="{{currentQ}}"><scroll-view class="question-area data-v-611e11c9" scroll-y="{{true}}"><view class="q-type data-v-611e11c9">{{"【"+(currentQ.type||'选择题')+"】"}}</view><view class="q-stem data-v-611e11c9">{{currentIdx+1+". "+currentQ.stem}}</view><view class="options data-v-611e11c9"><block wx:for="{{currentQ.options}}" wx:for-item="opt" wx:for-index="oi" wx:key="oi"><view data-event-opts="{{[['tap',[['selectOption',['$0'],[[['currentQ.options','',oi,'label']]]]]]]}}" class="{{['option-item','data-v-611e11c9',(answers[currentIdx]===opt.label)?'selected':'']}}" bindtap="__e"><view class="opt-label data-v-611e11c9">{{opt.label}}</view><view class="opt-text data-v-611e11c9">{{opt.text}}</view></view></block></view></scroll-view></block><view class="bottom-nav data-v-611e11c9"><view class="nav-btn data-v-611e11c9" disabled="{{currentIdx<=0}}" data-event-opts="{{[['tap',[['prevQ',['$event']]]]]}}" bindtap="__e">上一题</view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="nav-btn data-v-611e11c9" bindtap="__e">答题卡</view><block wx:if="{{currentIdx<$root.g2-1}}"><view data-event-opts="{{[['tap',[['nextQ',['$event']]]]]}}" class="nav-btn primary data-v-611e11c9" bindtap="__e">下一题</view></block><block wx:else><view data-event-opts="{{[['tap',[['confirmSubmit',['$event']]]]]}}" class="nav-btn danger data-v-611e11c9" bindtap="__e">交卷</view></block></view><block wx:if="{{showIndex}}"><view data-event-opts="{{[['tap',[['e2',['$event']]]]]}}" class="index-mask data-v-611e11c9" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="index-panel data-v-611e11c9" catchtap="__e"><view class="index-header data-v-611e11c9"><view class="index-title data-v-611e11c9">答题卡</view><view class="index-stats data-v-611e11c9">{{'已答 '+answeredCount+"/"+$root.g3+''}}</view></view><view class="index-grid data-v-611e11c9"><block wx:for="{{questions}}" wx:for-item="q" wx:for-index="qi" wx:key="qi"><view data-event-opts="{{[['tap',[['jumpTo',[qi]]]]]}}" class="{{['index-item','data-v-611e11c9',(qi===currentIdx)?'current':'',(answers[qi])?'answered':'']}}" bindtap="__e">{{qi+1}}</view></block></view><view class="index-legend data-v-611e11c9"><text class="legend-item data-v-611e11c9"><text class="dot answered-dot data-v-611e11c9"></text> 已答</text><text class="legend-item data-v-611e11c9"><text class="dot current-dot data-v-611e11c9"></text> 当前</text><text class="legend-item data-v-611e11c9"><text class="dot empty-dot data-v-611e11c9"></text> 未答</text></view><view data-event-opts="{{[['tap',[['confirmSubmit',['$event']]]]]}}" class="index-submit data-v-611e11c9" bindtap="__e">交卷</view></view></view></block></block><block wx:if="{{finished}}"><scroll-view class="result-area data-v-611e11c9" scroll-y="{{true}}"><view class="result-header data-v-611e11c9"><view class="{{['result-icon','data-v-611e11c9',resultLevel]}}">🏆</view><view class="result-score data-v-611e11c9">{{score}}</view><view class="result-label data-v-611e11c9">分</view><view class="result-level data-v-611e11c9">{{resultText}}</view></view><view class="result-card data-v-611e11c9"><view class="result-row data-v-611e11c9"><text class="rl data-v-611e11c9">总题数</text><text class="rv data-v-611e11c9">{{$root.g4}}</text></view><view class="result-row data-v-611e11c9"><text class="rl data-v-611e11c9">答对</text><text class="rv correct data-v-611e11c9">{{correctCount}}</text></view><view class="result-row data-v-611e11c9"><text class="rl data-v-611e11c9">答错</text><text class="rv wrong data-v-611e11c9">{{wrongCount}}</text></view><view class="result-row data-v-611e11c9"><text class="rl data-v-611e11c9">未答</text><text class="rv data-v-611e11c9">{{unansweredCount}}</text></view><view class="result-row data-v-611e11c9"><text class="rl data-v-611e11c9">正确率</text><text class="rv data-v-611e11c9">{{accuracy+"%"}}</text></view><view class="result-row data-v-611e11c9"><text class="rl data-v-611e11c9">用时</text><text class="rv data-v-611e11c9">{{usedTime}}</text></view></view><block wx:if="{{$root.g5>0}}"><view class="wrong-section data-v-611e11c9"><view class="wrong-title data-v-611e11c9">{{"错题回顾 ("+$root.g6+"题)"}}</view><block wx:for="{{wrongList}}" wx:for-item="item" wx:for-index="wi" wx:key="wi"><view class="wrong-item data-v-611e11c9"><view class="wrong-stem data-v-611e11c9">{{wi+1+". "+item.stem}}</view><view class="wrong-opts data-v-611e11c9"><text class="wo data-v-611e11c9">你的答案: <text class="wo-wrong data-v-611e11c9">{{item.userAnswer||'未答'}}</text></text><text class="wo data-v-611e11c9">正确答案: <text class="wo-correct data-v-611e11c9">{{item.answer}}</text></text></view><block wx:if="{{item.explanation}}"><view class="wrong-explain data-v-611e11c9"><text class="we-label data-v-611e11c9">【解析】</text>{{item.explanation+''}}</view></block></view></block></view></block><view class="result-actions data-v-611e11c9"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="result-btn data-v-611e11c9" bindtap="__e">返回首页</view><view data-event-opts="{{[['tap',[['retryExam',['$event']]]]]}}" class="result-btn primary data-v-611e11c9" bindtap="__e">再来一次</view></view></scroll-view></block></view>