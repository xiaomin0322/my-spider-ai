<view class="container data-v-3b9388b1"><view class="header data-v-3b9388b1"><view class="header-title data-v-3b9388b1">每日一练</view><view class="header-sub data-v-3b9388b1">每天随机10题，坚持练习</view></view><block wx:if="{{todayStats}}"><view class="today-card data-v-3b9388b1"><view class="today-title data-v-3b9388b1">今日进度</view><view class="today-stats data-v-3b9388b1"><view class="ts-item data-v-3b9388b1"><view class="ts-num data-v-3b9388b1">{{todayStats.answered}}</view><view class="ts-label data-v-3b9388b1">已答</view></view><view class="ts-item data-v-3b9388b1"><view class="ts-num correct data-v-3b9388b1">{{todayStats.correct}}</view><view class="ts-label data-v-3b9388b1">正确</view></view><view class="ts-item data-v-3b9388b1"><view class="ts-num wrong data-v-3b9388b1">{{todayStats.wrong}}</view><view class="ts-label data-v-3b9388b1">错误</view></view></view></view></block><view class="action-area data-v-3b9388b1"><button data-event-opts="{{[['tap',[['startPractice',['$event']]]]]}}" class="start-btn data-v-3b9388b1" bindtap="__e">{{''+(todayStats&&todayStats.answered>0?'继续练习':'开始今日练习')+''}}</button><view data-event-opts="{{[['tap',[['refreshDaily',['$event']]]]]}}" class="refresh-btn data-v-3b9388b1" bindtap="__e">换一批题目</view></view><block wx:if="{{$root.g0>0}}"><view class="section-title data-v-3b9388b1">历史记录</view></block><view class="history-list data-v-3b9388b1"><block wx:for="{{history}}" wx:for-item="h" wx:for-index="idx" wx:key="idx"><view class="history-item data-v-3b9388b1"><view class="h-date data-v-3b9388b1">{{h.date}}</view><view class="h-stats data-v-3b9388b1"><text class="data-v-3b9388b1">{{h.answered+"题"}}</text><text class="h-rate data-v-3b9388b1">{{"正确率 "+h.rate+"%"}}</text></view></view></block></view></view>